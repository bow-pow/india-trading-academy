rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Each authenticated user can only read/write their own document.
    // The user doc stores: currentDay, completed[], favorites[], notes{}, startedAt.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is denied by default.
  }
}
